NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autonomous_arb

# Arbitrum mainnet only.
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_PRIVATE_TX_RPC_URL=

# Executor service wallet (server-side only).
EXECUTOR_PRIVATE_KEY=0xREPLACE_WITH_64_HEX_PRIVATE_KEY
EXECUTOR_ADDRESS=0xREPLACE_WITH_EXECUTOR_ADDRESS
EXECUTOR_ENCRYPTION_KEY=replace-with-at-least-32-chars-random-string
AUTH_SESSION_SECRET=replace-with-at-least-32-chars-random-string
AUTH_CHALLENGE_TTL_SECONDS=300
AUTH_SESSION_TTL_SECONDS=86400
# Comma-separated lowercase wallet addresses allowed to trigger global pause/resume.
ADMIN_WALLETS=0xreplacewithadminwallet

# Instadapp/arb settings.
INSTAPOOL_ROUTE=5
FLASH_LOAN_FEE_BPS=9
MAX_JOB_RETRIES=3
WORKER_POLL_INTERVAL_MS=15000
WORKER_HEARTBEAT_SECONDS=30

# DEX contracts (Arbitrum mainnet).
UNISWAP_V3_QUOTER_V2=0x61fFE014bA17989E743c5F6cB21bF9697530B21e
UNISWAP_V3_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea31F984
SUSHISWAP_ROUTER=0x1b02da8cb0d097eb8d57a175b88c7d8b47997506
SUSHISWAP_FACTORY=0xc35DADB65012eC5796536bD9864eD8773aBc74C4

# Frontend wallet onboarding.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace-with-walletconnect-project-id
NEXT_PUBLIC_APP_NAME=Arbitrum Autonomous DSA Arb
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
